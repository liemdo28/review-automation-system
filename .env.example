# Database
DATABASE_URL=postgresql+asyncpg://reviews:reviews_dev@localhost:5432/review_system
DATABASE_URL_SYNC=postgresql+psycopg2://reviews:reviews_dev@localhost:5432/review_system

# Redis
REDIS_URL=redis://localhost:6379/0

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_ACCOUNT_ID=

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Email Alerts
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_EMAIL_TO=
ALERT_EMAIL_FROM=Review Bot <noreply@example.com>

# App
APP_URL=http://localhost:8000
DRY_RUN=true
SECRET_KEY=change-this-to-a-random-string
LOG_LEVEL=INFO

# Scheduling (minutes)
GOOGLE_FETCH_INTERVAL_MINUTES=30
YELP_FETCH_INTERVAL_MINUTES=60
PROCESS_INTERVAL_MINUTES=1
FETCH_INTERVAL_MINUTES=10

# Retry
MAX_RETRIES=3
FETCH_FAILURE_ALERT_THRESHOLD=3

# Auto-reply global default (per-store overrides in review_settings table)
AUTO_REPLY_GOOGLE_POSITIVE=false
