# Database
DATABASE_URL=postgresql+asyncpg://reviews:reviews_dev@localhost:5432/review_system
DATABASE_URL_SYNC=postgresql+psycopg2://reviews:reviews_dev@localhost:5432/review_system

# Redis
REDIS_URL=redis://localhost:6379/0

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
DEFAULT_REPLY_TONE=gentle_professional

# Web collector sessions
SESSION_STORAGE_DIR=.sessions
GOOGLE_BROWSER_PROXY=
YELP_BROWSER_PROXY=
GOOGLE_LOGIN_URL=https://www.google.com/
YELP_LOGIN_URL=https://biz.yelp.com/login
REVIEW_BROWSER_LOCALE=en-US
REVIEW_BROWSER_TIMEZONE=America/Los_Angeles

# Email Alerts
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_EMAIL_TO=
ALERT_EMAIL_FROM=Review Bot <noreply@example.com>

# App
DRY_RUN=true
FETCH_INTERVAL_MINUTES=10
PROCESS_INTERVAL_MINUTES=1
MAX_RETRIES=3
JOB_EXECUTION_MODE=inline
LOG_LEVEL=INFO
SECRET_KEY=change-this-to-a-random-string
UI_POSTING_HEADLESS=false
UI_POSTING_ARTIFACT_DIR=.run/ui-posting
UI_POSTING_MATCH_THRESHOLD=0.78
UI_POSTING_MATCH_MARGIN=0.08
