# Database
DATABASE_URL=postgresql+asyncpg://reviews:reviews_dev@localhost:5432/review_system
DATABASE_URL_SYNC=postgresql+psycopg2://reviews:reviews_dev@localhost:5432/review_system

# Redis
REDIS_URL=redis://localhost:6379/0

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_ACCOUNT_ID=

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
DEFAULT_REPLY_TONE=gentle_professional

# Email Alerts
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_EMAIL_TO=
ALERT_EMAIL_FROM=Review Bot <noreply@example.com>

# App
DRY_RUN=true
FETCH_INTERVAL_MINUTES=10
PROCESS_INTERVAL_MINUTES=1
MAX_RETRIES=3
JOB_EXECUTION_MODE=inline
LOG_LEVEL=INFO
SECRET_KEY=change-this-to-a-random-string
